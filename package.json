{
  "name": "logbook",
  "private": true,
  "version": "1.0.0",
  "description": "Logbook - Lokales Zeit-Logbuch mit Stoppuhr, Countdown und Pomodoro.",
  "author": "Logbook Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist release",
    "desktop:start": "electron .",
    "desktop:dev": "concurrently -k \"vite --port=3000 --host=127.0.0.1\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:3000 electron .\"",
    "build:desktop": "npm run build:renderer && electron-builder --publish never",
    "build:desktop:win": "npm run build:renderer && electron-builder --win nsis --x64 --publish never",
    "build:desktop:mac": "npm run build:renderer && electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "build:desktop:win:release": "npm run build:renderer && electron-builder --win nsis --x64 --publish always",
    "build:desktop:mac:release": "npm run build:renderer && electron-builder --mac dmg zip --x64 --arm64 --publish always"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.logbook.app",
    "productName": "Logbook",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "icon": "logo.png",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "logo.png"
    ],
    "asar": true,
    "win": {
      "icon": "logo.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "logo.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
